{
  "name": "@reporank/extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:chrome": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "build:safari": "plasmo build --target=safari-mv3",

    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "hosted-git-info": "^7.0",
    "react": "^18.3",
    "react-dom": "^18.3",
    "sharp": "^0.34.5"
  },
  "manifest": {
    "name": "RepoRank",
    "host_permissions": [
      "https://github.com/*",
      "https://gitlab.com/*",
      "https://npmjs.com/*",
      "https://bitbucket.org/*",
      "https://codeberg.org/*"
    ],
    "commands": {
      "_execute_action": {
        "suggested_key": {
          "default": "Ctrl+Shift+R",
          "mac": "Command+Shift+R"
        },
        "description": "Open RepoRank popup"
      }
    }
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "jsdom": "^29.1.1",
    "plasmo": "^0.90.5",
    "typescript": "^5.5",
    "vitest": "^1.6",
    "vitest-chrome-mv3": "^0.1"
  }
}
